{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Archiva API",
    "description": "Sistem Manajemen Dokumen dengan Version Control\n\nStatus dokumen: draft → reviewed → approved → archived\nReject: reviewed → rejected → (resubmit) → draft",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:3000/api" },
    { "key": "token",          "value": "" },
    { "key": "token_uploader", "value": "" },
    { "key": "token_reviewer", "value": "" },
    { "key": "token_approver", "value": "" },
    { "key": "document_id",    "value": "1" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
