    {
      "name": "2. Categories (CRUD)",
      "item": [
        {
          "name": "Create Category - Keuangan",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Keuangan\",\n  \"description\": \"Dokumen terkait keuangan perusahaan\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Category - SDM",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"SDM\",\n  \"description\": \"Dokumen Sumber Daya Manusia\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Category - Operasional",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Operasional\",\n  \"description\": \"Dokumen operasional harian\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/categories/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Keuangan & Akuntansi\",\n  \"description\": \"Dokumen keuangan dan akuntansi perusahaan\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/categories/3",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "3. Documents (CRUD)",
      "item": [
        {
          "name": "Create Document (dengan file)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('document_id', String(res.data.id));",
                  "  console.log('document_id saved:', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "Laporan Keuangan Q1 2025", "type": "text" },
                { "key": "description", "value": "Laporan keuangan kuartal pertama tahun 2025", "type": "text" },
                { "key": "category_id", "value": "1", "type": "text" },
                { "key": "file",        "type": "file", "src": "" }
              ]
            },
            "description": "Status otomatis `draft`. Versi file v1 tercatat otomatis di document_versions."
          }
        },
        {
          "name": "Create Document (tanpa file)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "SOP Rekrutmen Karyawan", "type": "text" },
                { "key": "description", "value": "Standar operasional rekrutmen", "type": "text" },
                { "key": "category_id", "value": "2", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Create Document as Uploader",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "Nota Dinas Budi", "type": "text" },
                { "key": "description", "value": "Nota dinas dari Budi", "type": "text" },
                { "key": "category_id", "value": "2", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Get All Documents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?page=1&limit=10",
              "query": [
                { "key": "page",        "value": "1" },
                { "key": "limit",       "value": "10" },
                { "key": "search",      "value": "laporan",  "disabled": true },
                { "key": "category_id", "value": "1",        "disabled": true },
                { "key": "status",      "value": "draft",    "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get All Documents - Filter by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?status=draft",
              "query": [{ "key": "status", "value": "draft" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Status valid: draft | reviewed | approved | rejected | archived"
          }
        },
        {
          "name": "Get All Documents - Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?search=laporan",
              "query": [{ "key": "search", "value": "laporan" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Pencarian mencakup title dan description."
          }
        },
        {
          "name": "Get All Documents as Uploader (hanya milik sendiri)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }]
          }
        },
        {
          "name": "Get Document by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Document (metadata only)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "Laporan Keuangan Q1 2025 (Revisi)", "type": "text" },
                { "key": "description", "value": "Update deskripsi",                   "type": "text" }
              ]
            },
            "description": "Uploader hanya bisa update dokumen berstatus draft atau rejected."
          }
        },
        {
          "name": "Update Document (ganti file — buat versi baru)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",        "value": "Laporan Keuangan Q1 2025 (Revisi)",    "type": "text" },
                { "key": "version_note", "value": "Perbaikan data di tabel arus kas",      "type": "text" },
                { "key": "file",         "type": "file", "src": "" }
              ]
            },
            "description": "Upload file baru → versi dokumen naik otomatis (v1 → v2). Field `version_note` opsional."
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "4. Workflow — Review, Approve, Reject, Archive",
      "item": [
        {
          "name": "Review Dokumen (reviewer) — draft → reviewed",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/review",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_reviewer}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Dokumen sudah diperiksa dan sesuai standar.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Hanya reviewer atau admin. Dokumen harus berstatus draft."
          }
        },
        {
          "name": "Approve Dokumen (approver) — reviewed → approved",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/approve",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_approver}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Disetujui. Laporan sesuai standar akuntansi perusahaan.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Hanya approver atau admin. Dokumen harus berstatus reviewed."
          }
        },
        {
          "name": "Reject Dokumen (approver) — reviewed → rejected",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/reject",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_approver}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Ditolak. Terdapat kesalahan penghitungan pada tabel arus kas.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Hanya approver atau admin. Dokumen harus berstatus draft atau reviewed."
          }
        },
        {
          "name": "Resubmit Dokumen (uploader) — rejected → draft",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/resubmit",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_uploader}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Sudah diperbaiki sesuai catatan. Siap direview ulang.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Hanya pemilik dokumen atau admin. Dokumen harus berstatus rejected."
          }
        },
        {
          "name": "Archive Dokumen (admin) — approved → archived",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/archive",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Diarsipkan sebagai dokumen final Q1 2025.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Hanya admin. Dokumen harus berstatus approved."
          }
        }
      ]
    },
    {
      "name": "5. Komentar",
      "item": [
        {
          "name": "Get Comments",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}/comments",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Semua role bisa melihat komentar dokumen yang relevan."
          }
        },
        {
          "name": "Add Comment (reviewer)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/comments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_reviewer}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Mohon perbaiki angka di tabel halaman 3.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Add Comment (approver)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/comments",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_approver}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Secara keseluruhan sudah baik, tinggal perbaikan minor.\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "6. Versi & Histori",
      "item": [
        {
          "name": "Get Versions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}/versions",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Lihat semua versi file yang pernah diupload (v1, v2, v3, ...)."
          }
        },
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Lihat log perubahan status: created, updated, reviewed, approved, rejected, resubmitted, archived, commented."
          }
        }
      ]
    },
    {
      "name": "7. Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "description": "Jumlah dokumen per status, per kategori, dan user per role. Hanya reviewer/approver/admin."
          }
        },
        {
          "name": "Get Dashboard Stats (as Reviewer)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_reviewer}}" }]
          }
        }
      ]
    },
    {
      "name": "8. Role & Authorization Test",
      "item": [
        {
          "name": "❌ Akses Tanpa Token → 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents"
          }
        },
        {
          "name": "❌ Token Tidak Valid → 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer token_palsu_tidak_valid" }]
          }
        },
        {
          "name": "❌ Uploader Buat Kategori → 403",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_uploader}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kategori Baru\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "❌ Uploader Review Dokumen → 403",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/review",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_uploader}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"note\": \"Coba review sendiri\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "❌ Reviewer Approve Dokumen → 403",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents/{{document_id}}/approve",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_reviewer}}" },
