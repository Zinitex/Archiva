{
  "info": {
    "_postman_id": "archiva-userflow-v1",
    "name": "Archiva — Document Version Control (User Flow Demo)",
    "description": "Koleksi demo alur lengkap sistem manajemen dokumen Archiva.\n\nAlur: Setup → Admin buat kategori → Uploader upload dokumen → Reviewer review → Approver approve → Admin kelola.\n\nVariabel otomatis tersimpan via test script setiap login/create.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",       "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token_admin",    "value": "", "type": "string" },
    { "key": "token_uploader", "value": "", "type": "string" },
    { "key": "token_reviewer", "value": "", "type": "string" },
    { "key": "token_approver", "value": "", "type": "string" },
    { "key": "category_id",    "value": "1", "type": "string" },
    { "key": "document_id",    "value": "1", "type": "string" }
  ],
  "item": [

    {
      "name": "01 · Setup — Registrasi & Login",
      "description": "Langkah pertama: daftarkan semua role yang dibutuhkan lalu login untuk mendapatkan token masing-masing.",
      "item": [
        {
          "name": "Register — Admin",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Archiva\",\n  \"email\": \"admin@archiva.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Daftarkan akun Admin. Jalankan sekali saja."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Registrasi berhasil\",\n  \"data\": {\n    \"id\": 1,\n    \"name\": \"Admin Archiva\",\n    \"email\": \"admin@archiva.com\",\n    \"role\": \"admin\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Register — Uploader",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Budi Uploader\",\n  \"email\": \"budi@archiva.com\",\n  \"password\": \"password123\",\n  \"role\": \"uploader\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Daftarkan akun Uploader (pembuat dokumen)."
          }
        },
        {
          "name": "Register — Reviewer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Siti Reviewer\",\n  \"email\": \"siti@archiva.com\",\n  \"password\": \"password123\",\n  \"role\": \"reviewer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Daftarkan akun Reviewer (memeriksa dokumen)."
          }
        },
        {
          "name": "Register — Approver",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Doni Approver\",\n  \"email\": \"doni@archiva.com\",\n  \"password\": \"password123\",\n  \"role\": \"approver\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Daftarkan akun Approver (menyetujui dokumen final)."
          }
        },
        {
          "name": "Login — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token_admin', res.data.token);",
                  "  console.log('✅ token_admin saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@archiva.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login sebagai Admin. Token otomatis tersimpan ke variabel `token_admin`."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Login berhasil\",\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"user\": { \"id\": 1, \"name\": \"Admin Archiva\", \"email\": \"admin@archiva.com\", \"role\": \"admin\" }\n  }\n}"
            }
          ]
        },
        {
          "name": "Login — Uploader",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token_uploader', res.data.token);",
                  "  console.log('✅ token_uploader saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"budi@archiva.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login sebagai Uploader. Token otomatis tersimpan ke variabel `token_uploader`."
          }
        },
        {
          "name": "Login — Reviewer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token_reviewer', res.data.token);",
                  "  console.log('✅ token_reviewer saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"siti@archiva.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login sebagai Reviewer. Token otomatis tersimpan ke `token_reviewer`."
          }
        },
        {
          "name": "Login — Approver",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token_approver', res.data.token);",
                  "  console.log('✅ token_approver saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"doni@archiva.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login sebagai Approver. Token otomatis tersimpan ke `token_approver`."
          }
        },
        {
          "name": "Get My Profile (Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Verifikasi bahwa token Admin valid dan berisi data profil yang benar."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": { \"id\": 1, \"name\": \"Admin Archiva\", \"email\": \"admin@archiva.com\", \"role\": \"admin\" }\n}"
            }
          ]
        },
        {
          "name": "Server Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/status",
            "description": "Cek status server — tidak butuh token."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"timestamp\": \"2025-06-01T10:00:00.000Z\",\n  \"environment\": \"development\",\n  \"version\": \"v20.x.x\"\n}"
            }
          ]
        }
      ]
    },

    {
      "name": "02 · Admin — Setup Kategori",
      "description": "Admin membuat kategori dokumen sebelum Uploader bisa mengunggah. Hanya Admin yang bisa create/update/delete kategori.",
      "item": [
        {
          "name": "Create Category — Keuangan",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('category_id', String(res.data.id));",
                  "  console.log('✅ category_id saved:', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Keuangan\",\n  \"description\": \"Laporan keuangan, anggaran, dan audit perusahaan\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Buat kategori Keuangan. ID otomatis tersimpan ke `category_id`."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Kategori berhasil dibuat\",\n  \"data\": { \"id\": 1, \"name\": \"Keuangan\", \"description\": \"Laporan keuangan, anggaran, dan audit perusahaan\" }\n}"
            }
          ]
        },
        {
          "name": "Create Category — SDM",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"SDM\",\n  \"description\": \"Dokumen Sumber Daya Manusia dan rekrutmen\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Category — Operasional",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Operasional\",\n  \"description\": \"SOP dan dokumen operasional harian\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Create Category — Legal",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Legal\",\n  \"description\": \"Dokumen hukum, kontrak, dan regulasi\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Lihat semua kategori yang sudah dibuat."
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/{{category_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Detail satu kategori berdasarkan ID."
          }
        },
        {
          "name": "Update Category — Rename Keuangan",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/categories/{{category_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_admin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Keuangan & Akuntansi\",\n  \"description\": \"Laporan keuangan, akuntansi, dan audit perusahaan\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Perbarui nama dan deskripsi kategori."
          }
        },
        {
          "name": "Delete Category (kategori kosong)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/categories/4",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Hapus kategori Legal (ID 4) yang belum memiliki dokumen."
          }
        }
      ]
    },

    {
      "name": "03 · Uploader — Upload & Revisi Dokumen",
      "description": "Uploader membuat dokumen baru, mengunggah file, lalu merevisi dengan mengganti file (simulasi version control — file lama otomatis terhapus, diganti file baru).",
      "item": [
        {
          "name": "Upload Dokumen v1 — dengan File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('document_id', String(res.data.id));",
                  "  console.log('✅ document_id saved:', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "Laporan Keuangan Q1 2025",                         "type": "text" },
                { "key": "description", "value": "Draft laporan keuangan kuartal pertama tahun 2025", "type": "text" },
                { "key": "category_id", "value": "1",                                                 "type": "text" },
                { "key": "status",      "value": "draft",                                             "type": "text" },
                { "key": "file",        "type": "file", "src": "" }
              ]
            },
            "description": "Upload dokumen pertama (v1) dengan status `draft`. Lampirkan file PDF/DOCX. ID dokumen tersimpan ke `document_id`."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Dokumen berhasil dibuat\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Laporan Keuangan Q1 2025\",\n    \"status\": \"draft\",\n    \"original_filename\": \"laporan-q1.pdf\",\n    \"file_size\": 204800,\n    \"mime_type\": \"application/pdf\",\n    \"user_id\": 2,\n    \"category_id\": 1\n  }\n}"
            }
          ]
        },
        {
          "name": "Upload Dokumen — Tanpa File (metadata only)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "SOP Rekrutmen Karyawan 2025",              "type": "text" },
                { "key": "description", "value": "Standar operasional proses rekrutmen baru", "type": "text" },
                { "key": "category_id", "value": "2",                                          "type": "text" },
                { "key": "status",      "value": "draft",                                      "type": "text" }
              ]
            },
            "description": "Buat dokumen tanpa lampiran file — hanya metadata."
          }
        },
        {
          "name": "Lihat Semua Dokumen Milik Sendiri",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?page=1&limit=10",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "description": "Uploader hanya melihat dokumen miliknya sendiri (difilter otomatis oleh server)."
          }
        },
        {
          "name": "Lihat Dokumen by Status — Draft",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?status=draft",
              "query": [{ "key": "status", "value": "draft" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "description": "Filter dokumen yang masih berstatus draft."
          }
        },
        {
          "name": "Lihat Detail Dokumen",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "description": "Lihat detail lengkap satu dokumen termasuk metadata file dan kategori."
          }
        },
        {
          "name": "Edit Metadata Dokumen (tanpa ganti file)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "Laporan Keuangan Q1 2025 — Revisi Judul", "type": "text" },
                { "key": "description", "value": "Update deskripsi tanpa mengganti file",    "type": "text" }
              ]
            },
            "description": "Ubah judul/deskripsi tanpa mengganti file yang sudah ada."
          }
        },
        {
          "name": "Upload Revisi File — Dokumen v2 (Version Control)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "Laporan Keuangan Q1 2025 (Revisi)",    "type": "text" },
                { "key": "description", "value": "File diperbarui — revisi setelah review internal", "type": "text" },
                { "key": "file",        "type": "file", "src": "" }
              ]
            },
            "description": "Ganti file dengan versi terbaru (v2). File lama otomatis dihapus dari server dan diganti file baru — ini mekanisme version control Archiva."
          },
          "response": [
            {
              "name": "200 OK — File Replaced",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Dokumen berhasil diupdate\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Laporan Keuangan Q1 2025 (Revisi)\",\n    \"original_filename\": \"laporan-q1-revisi.pdf\",\n    \"status\": \"draft\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Cari Dokumen by Kata Kunci",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?search=laporan",
              "query": [{ "key": "search", "value": "laporan" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "description": "Cari dokumen yang judulnya mengandung kata 'laporan'."
          }
        }
      ]
    },

    {
      "name": "04 · Reviewer — Periksa & Publikasikan",
      "description": "Reviewer melihat semua dokumen draft, melakukan review, lalu mengubah status ke `published` sebagai tanda dokumen sudah diperiksa.",
      "item": [
        {
          "name": "Lihat Semua Dokumen Draft (perlu direview)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?status=draft&page=1&limit=20",
              "query": [
                { "key": "status", "value": "draft" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_reviewer}}" }],
            "description": "Reviewer melihat seluruh dokumen berstatus draft yang menunggu review."
          }
        },
        {
          "name": "Lihat Detail Dokumen yang Akan Direview",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_reviewer}}" }],
            "description": "Buka detail dokumen sebelum memberikan keputusan."
          }
        },
        {
          "name": "Filter Dokumen by Kategori",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?category_id=1&status=draft",
              "query": [
                { "key": "category_id", "value": "1" },
                { "key": "status",      "value": "draft" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_reviewer}}" }],
            "description": "Filter dokumen draft di kategori Keuangan (ID 1) saja."
          }
        },
        {
          "name": "Publikasikan Dokumen — Status: draft → published",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_reviewer}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "status", "value": "published", "type": "text" }
              ]
            },
            "description": "Reviewer mengubah status dokumen dari `draft` ke `published`. Dokumen siap untuk di-approve."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Dokumen berhasil diupdate\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Laporan Keuangan Q1 2025 (Revisi)\",\n    \"status\": \"published\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Lihat Semua Dokumen Published",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?status=published",
              "query": [{ "key": "status", "value": "published" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_reviewer}}" }],
            "description": "Verifikasi dokumen sudah masuk ke status published."
          }
        }
      ]
    },

    {
      "name": "05 · Approver — Setujui & Arsipkan",
      "description": "Approver melihat dokumen yang sudah published, lalu mengubah status ke `archived` sebagai tanda dokumen final dan diarsipkan.",
      "item": [
        {
          "name": "Lihat Semua Dokumen Published (siap approve)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?status=published",
              "query": [{ "key": "status", "value": "published" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_approver}}" }],
            "description": "Approver melihat dokumen yang sudah direview dan siap disetujui."
          }
        },
        {
          "name": "Lihat Detail Dokumen Final",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_approver}}" }],
            "description": "Buka detail dokumen untuk keputusan final."
          }
        },
        {
          "name": "Approve Dokumen — Status: published → archived",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_approver}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "status", "value": "archived", "type": "text" }
              ]
            },
            "description": "Approver menyetujui dan mengarsipkan dokumen. Status berubah dari `published` ke `archived` — ini state final dokumen."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Dokumen berhasil diupdate\",\n  \"data\": {\n    \"id\": 1,\n    \"title\": \"Laporan Keuangan Q1 2025 (Revisi)\",\n    \"status\": \"archived\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Lihat Semua Dokumen Archived",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?status=archived",
              "query": [{ "key": "status", "value": "archived" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_approver}}" }],
            "description": "Lihat seluruh dokumen yang sudah final dan diarsipkan."
          }
        }
      ]
    },

    {
      "name": "06 · Admin — Manajemen Penuh",
      "description": "Admin memiliki akses penuh: melihat semua dokumen dari semua user, menghapus dokumen siapapun, dan mengelola kategori.",
      "item": [
        {
          "name": "Lihat Semua Dokumen — Semua User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?page=1&limit=20",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Admin melihat semua dokumen dari semua user (tidak difilter per user)."
          }
        },
        {
          "name": "Filter: Semua Dokumen Draft",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?status=draft",
              "query": [{ "key": "status", "value": "draft" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }]
          }
        },
        {
          "name": "Filter: Semua Dokumen by Kategori",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?category_id=1",
              "query": [{ "key": "category_id", "value": "1" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }]
          }
        },
        {
          "name": "Cari Dokumen — Full Text Search",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/documents?search=laporan&page=1&limit=10",
              "query": [
                { "key": "search", "value": "laporan" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }]
          }
        },
        {
          "name": "Admin Update Dokumen User Lain",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",  "value": "Laporan Keuangan Q1 2025 — Dikoreksi Admin", "type": "text" },
                { "key": "status", "value": "published",                                   "type": "text" }
              ]
            },
            "description": "Admin bisa mengupdate dokumen milik user manapun."
          }
        },
        {
          "name": "Admin Hapus Dokumen Siapapun",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/documents/{{document_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Admin menghapus dokumen. File fisik di server juga ikut terhapus."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Dokumen berhasil dihapus\"\n}"
            }
          ]
        },
        {
          "name": "Get All Categories (audit)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }]
          }
        }
      ]
    },

    {
      "name": "07 · Error Cases — Validasi & Otorisasi",
      "description": "Kumpulan kasus error yang menunjukkan sistem keamanan berjalan dengan benar: 401 Unauthorized, 403 Forbidden, 404 Not Found, 400 Bad Request.",
      "item": [
        {
          "name": "❌ 401 — Akses Tanpa Token",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents",
            "description": "Request tanpa header Authorization → 401 Unauthorized."
          },
          "response": [
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Token tidak ditemukan\"\n}"
            }
          ]
        },
        {
          "name": "❌ 401 — Token Tidak Valid / Expired",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer token_palsu_tidak_valid_12345" }],
            "description": "Token palsu atau sudah expired → 401."
          },
          "response": [
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Token tidak valid\"\n}"
            }
          ]
        },
        {
          "name": "❌ 401 — Login Password Salah",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@archiva.com\",\n  \"password\": \"passwordsalah\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Kredensial salah → 401."
          },
          "response": [
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Email atau password salah\"\n}"
            }
          ]
        },
        {
          "name": "❌ 409 — Register Email Sudah Terdaftar",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Duplikat\",\n  \"email\": \"admin@archiva.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Email sudah dipakai → 409 Conflict."
          },
          "response": [
            {
              "name": "409 Conflict",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"message\": \"Email sudah terdaftar\"\n}"
            }
          ]
        },
        {
          "name": "❌ 403 — Uploader Buat Kategori (forbidden)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_uploader}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kategori Ilegal\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Hanya Admin yang boleh membuat kategori → 403 Forbidden."
          },
          "response": [
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"message\": \"Akses ditolak\"\n}"
            }
          ]
        },
        {
          "name": "❌ 403 — Uploader Hapus Dokumen Orang Lain",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/documents/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "description": "Uploader mencoba menghapus dokumen milik Admin → 403."
          },
          "response": [
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"message\": \"Tidak diizinkan menghapus dokumen ini\"\n}"
            }
          ]
        },
        {
          "name": "❌ 403 — Uploader Edit Dokumen Orang Lain",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/documents/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Coba Ubah Dokumen Orang Lain", "type": "text" }
              ]
            },
            "description": "Uploader mencoba mengubah dokumen yang bukan miliknya → 403."
          },
          "response": [
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"message\": \"Tidak diizinkan mengubah dokumen ini\"\n}"
            }
          ]
        },
        {
          "name": "❌ 404 — Dokumen Tidak Ada",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/documents/99999",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Dokumen dengan ID 99999 tidak ada → 404 Not Found."
          },
          "response": [
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"message\": \"Dokumen tidak ditemukan\"\n}"
            }
          ]
        },
        {
          "name": "❌ 404 — Kategori Tidak Ada",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories/99999",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "description": "Kategori dengan ID 99999 tidak ada → 404."
          }
        },
        {
          "name": "❌ 400 — Buat Dokumen Tanpa Title",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "description", "value": "Tidak ada title",  "type": "text" },
                { "key": "category_id", "value": "1",                "type": "text" }
              ]
            },
            "description": "Field `title` wajib diisi → 400 Bad Request."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"message\": \"title wajib diisi\"\n}"
            }
          ]
        },
        {
          "name": "❌ 400 — Buat Dokumen Tanpa Category",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Dokumen Tanpa Kategori", "type": "text" }
              ]
            },
            "description": "Field `category_id` wajib diisi → 400 Bad Request."
          },
          "response": [
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"message\": \"category_id wajib diisi\"\n}"
            }
          ]
        },
        {
          "name": "❌ 404 — Buat Dokumen ke Kategori Tidak Ada",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/documents",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_uploader}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",       "value": "Dokumen Kategori Tidak Valid", "type": "text" },
                { "key": "category_id", "value": "9999",                          "type": "text" }
              ]
            },
            "description": "Category ID 9999 tidak ada di database → 404."
          },
          "response": [
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"message\": \"Kategori tidak ditemukan\"\n}"
            }
          ]
        }
      ]
    }

  ]
}
